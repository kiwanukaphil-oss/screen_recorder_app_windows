<Window
    x:Class="Recorder.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Screen Recorder"
                   Style="{StaticResource TitleTextBlockStyle}" />

        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Text="Source" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <ComboBox x:Name="SourcePicker" HorizontalAlignment="Stretch"
                      DropDownOpened="OnSourcePickerOpened" />
        </StackPanel>

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="Audio" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ToggleSwitch x:Name="SystemAudioToggle" Header="System audio" IsOn="True" />
                <ToggleSwitch x:Name="MicrophoneToggle" Header="Microphone" IsOn="False" />
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock Text="Video" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ComboBox x:Name="CodecPicker" Header="Codec" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="H.264" IsSelected="True" />
                    <ComboBoxItem Content="HEVC" />
                </ComboBox>
                <ComboBox x:Name="FpsPicker" Header="Frame rate" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="30" />
                    <ComboBoxItem Content="60" IsSelected="True" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button x:Name="RecordButton" Grid.Column="0"
                    HorizontalAlignment="Stretch" Height="56"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnRecordButtonClick">
                <TextBlock x:Name="RecordButtonLabel" Text="● Start recording"
                           FontSize="18" />
            </Button>
            <Button x:Name="PauseButton" Grid.Column="1"
                    HorizontalAlignment="Stretch" Height="56"
                    IsEnabled="False"
                    Click="OnPauseButtonClick">
                <TextBlock x:Name="PauseButtonLabel" Text="⏸ Pause" FontSize="16" />
            </Button>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="4"
                   Text="Ready. Ctrl+Shift+F9 stops recording from anywhere."
                   TextWrapping="Wrap"
                   Style="{StaticResource BodyTextBlockStyle}" />

        <Button Grid.Row="5" HorizontalAlignment="Stretch"
                Content="Open recordings folder" Click="OnOpenFolderClick" />
    </Grid>
</Window>
